{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SDI Floor Deck Unshored Span Calculator",
  "description": "Calculator for max unshored span of steel decking.",
  "type": "object",
  "properties": {
    "15x6_image": {
      "type": "string",
      "description": "15x6_image"
    },
    "15x6Inverted_image": {
      "type": "string",
      "description": "15x6Inverted_image"
    },
    "2x12_image": {
      "type": "string",
      "description": "2x12_image"
    },
    "3x12_image": {
      "type": "string",
      "description": "3x12_image"
    },
    "9-16x25_image": {
      "type": "string",
      "description": "9-16x25_image"
    },
    "1x4_image": {
      "type": "string",
      "description": "1x4_image"
    },
    "Custom_image": {
      "type": "string",
      "description": "Custom_image"
    },
    "decking_profile_input": {
      "type": "string",
      "description": "Decking Profile. Symbol: Profile. Select the profile (shape) of SDI decking sheet.",
      "enum": [
        "1.5x6",
        "1.5x6Inverted",
        "2x12",
        "3x12",
        "9/16x2.5",
        "1x4",
        "Custom"
      ],
      "x-enumLabels": [
        "1.5 x 6",
        "1.5 x 6 Inverted",
        "2 x 12",
        "3 x 12",
        "9/16 x 2.5",
        "1 x 4",
        "Custom"
      ],
      "default": "3x12"
    },
    "decking_profile_custom": {
      "type": "string",
      "description": "Profile Name. Symbol: Custom \\; Profile. Enter the name of the custom decking profile.",
      "default": "Custom Profile"
    },
    "custom_profile_table": {
      "type": "array",
      "description": "Section Properties",
      "items": {
        "type": "object",
        "properties": {
          "deck_height_custom": {
            "type": "number",
            "description": "Deck Height (in)",
            "default": 3,
            "minimum": 0,
            "maximum": 10000
          },
          "deck_spacing_custom": {
            "type": "number",
            "description": "Deck Spacing (in)",
            "default": 12,
            "minimum": 0,
            "maximum": 10000
          },
          "deck_gage_custom": {
            "type": "number",
            "description": "Decking Gage",
            "default": 18,
            "minimum": 0,
            "maximum": 10000
          },
          "yield_strength_custom": {
            "type": "number",
            "description": "Yield Strength (ksi)",
            "default": 40,
            "minimum": 0,
            "maximum": 10000
          },
          "As_custom": {
            "type": "number",
            "description": "Cross Section Area (in2)",
            "default": 0.75,
            "minimum": 0,
            "maximum": 100000
          },
          "I_custom": {
            "type": "number",
            "description": "Moment of Inertia (in4)",
            "default": 1.5,
            "minimum": 0,
            "maximum": 100000
          },
          "section_modulus_pos_custom": {
            "type": "number",
            "description": "Positive Section Modulus (in3)",
            "default": 0.75,
            "minimum": 0,
            "maximum": 100000
          },
          "section_modulus_neg_custom": {
            "type": "number",
            "description": "Negative Section Modulus (in3)",
            "default": 0.75,
            "minimum": 0,
            "maximum": 100000
          },
          "shear_capacity_custom": {
            "type": "number",
            "description": "Shear Capacity (lbs)",
            "default": 6000,
            "minimum": 0,
            "maximum": 100000
          },
          "ext_crippling_custom": {
            "type": "number",
            "description": "Exterior Crippling Capacity (lbs)",
            "default": 1500,
            "minimum": 0,
            "maximum": 100000
          },
          "int_crippling_custom": {
            "type": "number",
            "description": "Interior Crippling Capacity (lbs)",
            "default": 1500,
            "minimum": 0,
            "maximum": 100000
          },
          "ext_min_bearing": {
            "type": "number",
            "description": "Exterior Min Bearing Length (in)",
            "default": 3,
            "minimum": 0,
            "maximum": 100000
          },
          "int_min_bearing": {
            "type": "number",
            "description": "Interior Min Bearing Length (in)",
            "default": 4,
            "minimum": 0,
            "maximum": 100000
          },
          "cv_custom": {
            "type": "number",
            "description": "Deck Volume Constant (ft)",
            "default": 0.15,
            "minimum": 0,
            "maximum": 100
          },
          "deck_weight_custom": {
            "type": "number",
            "description": "Decking Weight (psf)",
            "default": 2.5,
            "minimum": 0,
            "maximum": 100000
          }
        }
      }
    },
    "decking_gage_standard": {
      "type": "number",
      "description": "Decking Gage. Symbol: Gage. Select the gage (thickness) of decking sheet. Note, only 9/16x2.5 and 1x4 profiles support 24 and 26 gage steel.",
      "enum": [
        22,
        20,
        18,
        16
      ],
      "x-enumLabels": [
        "22",
        "20",
        "18",
        "16"
      ],
      "default": 18
    },
    "decking_gage_alt": {
      "type": "number",
      "description": "Decking Gage. Symbol: Gage. Select the gage (thickness) of decking sheet.",
      "enum": [
        26,
        24,
        22,
        20,
        18,
        16
      ],
      "x-enumLabels": [
        "26",
        "24",
        "22",
        "20",
        "18",
        "16"
      ],
      "default": 18
    },
    "yield_strength_input": {
      "type": "number",
      "description": "Yield Strength. Symbol: Yield \\; Strength. Units: ksi. Select the yield strength (in ksi) of the SDI decking sheet.",
      "enum": [
        33,
        40,
        50,
        80
      ],
      "x-enumLabels": [
        "33",
        "40",
        "50",
        "80"
      ],
      "default": 50
    },
    "no_spans": {
      "type": "number",
      "description": "No. Spans. Symbol: No. \\; Spans. Select from 1, 2 or 3 spans of metal decking.",
      "enum": [
        1,
        2,
        3
      ],
      "x-enumLabels": [
        "1",
        "2",
        "3"
      ],
      "default": 3
    },
    "end_bearing": {
      "type": "number",
      "description": "End Bearing Width. Symbol: End\\; Bearing. Units: in. The bearing support width for decking sheets at the ends of the continuous spans.",
      "default": 12,
      "minimum": 0,
      "maximum": 10000
    },
    "interior_bearing": {
      "type": "number",
      "description": "Interior Bearing Width. Symbol: Interior\\; Bearing. Units: in. The bearing support width for decking sheets at internal supports.",
      "default": 12,
      "minimum": 0,
      "maximum": 10000
    },
    "slab_depth": {
      "type": "number",
      "description": "Slab Depth. Symbol: Slab\\; Depth. Units: in. Total depth of concrete slab poured over decking.",
      "default": 7.5,
      "minimum": 3,
      "maximum": 10000
    },
    "concrete_density": {
      "type": "number",
      "description": "Concrete Density. Symbol: Concrete\\; Density. Units: lb/ft^3. Density of concrete poured over decking.",
      "default": 145,
      "minimum": 30,
      "maximum": 300
    },
    "surcharge_load": {
      "type": "number",
      "description": "Surcharge Loading. Symbol: Surcharge\\; Load. Units: psf. Additional concrete surcharge loading due to ponding during placement.",
      "default": 30,
      "minimum": 0,
      "maximum": 10000
    },
    "live_load": {
      "type": "number",
      "description": "Construction Loading. Symbol: Live\\; Load. Units: psf. Construction live loading applied to decking (min 20psf).",
      "default": 20,
      "minimum": 20,
      "maximum": 10000
    },
    "design_methodology": {
      "type": "string",
      "description": "Design Methodology. Symbol: Methodology. Select from ASD or LFRD design methodology.",
      "enum": [
        "LFRD",
        "ASD"
      ],
      "x-enumLabels": [
        "LFRD",
        "ASD"
      ],
      "default": "LFRD"
    },
    "deflection_criteria": {
      "type": "number",
      "description": "Deflection Criteria. Symbol: Deflection. Select the deflection limits that should be checked.",
      "enum": [
        180,
        240
      ],
      "x-enumLabels": [
        "L/180",
        "L/240"
      ],
      "default": 180
    },
    "deflection_limit": {
      "type": "number",
      "description": "Deflection Limit. Symbol: δ_{Limit}. Units: in. Maximum allowable deflection during concrete/live loading.",
      "default": 0.75,
      "minimum": 0,
      "maximum": 10000
    },
    "uid": {
      "type": "string",
      "const": "9024-sdi-unshored-span-calculator",
      "description": "Calculator unique identifier — must match the endpoint uid."
    },
    "current_unit_system": {
      "type": "string",
      "enum": [
        "metric",
        "imperial",
        ""
      ],
      "default": "metric",
      "description": "Unit system for input values and output display."
    },
    "project_details": {
      "type": "object",
      "description": "Optional project metadata for the PDF report header.",
      "properties": {
        "project_company": {
          "type": "string",
          "default": ""
        },
        "project_name": {
          "type": "string",
          "default": ""
        },
        "project_designer": {
          "type": "string",
          "default": ""
        },
        "project_id": {
          "type": "string",
          "default": ""
        },
        "project_client": {
          "type": "string",
          "default": ""
        },
        "project_notes": {
          "type": "string",
          "default": ""
        }
      }
    }
  }
}