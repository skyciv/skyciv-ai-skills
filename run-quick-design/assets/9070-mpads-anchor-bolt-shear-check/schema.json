{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Anchor check for ULS Shear as per SESOC Base Plate Design Guide Ch 4.7",
  "description": "Anchor check for ULS Shear as per SESOC Base Plate Design Guide Ch 4.7",
  "type": "object",
  "properties": {
    "image": {
      "type": "string",
      "description": "image. Diagram of Anchor Bolt"
    },
    "fc": {
      "type": "number",
      "description": "Concrete Compressive Strength. Symbol: f'c. Units: MPa",
      "default": 28,
      "minimum": 12.5,
      "maximum": 100
    },
    "fy_plate": {
      "type": "number",
      "description": "Yield Strength of Plate. Symbol: f'c. Units: MPa",
      "default": 248,
      "minimum": 200,
      "maximum": 1000
    },
    "fu_plate": {
      "type": "number",
      "description": "Tensile Strength of Plate. Symbol: f'c. Units: MPa",
      "default": 400,
      "minimum": 200,
      "maximum": 1500
    },
    "bolt_grade": {
      "type": "number",
      "description": "Bolt Grade. Symbol: Gr. Bolt Grade as per ASTM",
      "enum": [
        4.6,
        8.8
      ],
      "x-enumLabels": [
        "Grade 4.6",
        "Grade 8.8"
      ],
      "default": 4.6
    },
    "df": {
      "type": "number",
      "description": "Bolt Diameter. Symbol: df. Bolt Diameter",
      "enum": [
        6,
        8,
        10,
        12,
        16,
        20,
        24,
        30,
        36
      ],
      "x-enumLabels": [
        "M6",
        "M8",
        "M10",
        "M12",
        "M16",
        "M20",
        "M24",
        "M30",
        "M36"
      ],
      "default": 16
    },
    "g": {
      "type": "number",
      "description": "Thickness of grout under base plate. Symbol: g. Units: mm",
      "default": 15,
      "minimum": 0,
      "maximum": 75
    },
    "Vs_bp": {
      "type": "number",
      "description": "ULS Shear for whole base plate. Symbol: Vs_bp. Units: kN",
      "default": 10,
      "minimum": 0,
      "maximum": 5000
    },
    "no_b": {
      "type": "number",
      "description": "No. of Bolts. Symbol: no_b",
      "default": 4,
      "minimum": 2,
      "maximum": 20
    },
    "uid": {
      "type": "string",
      "const": "9070-mpads-anchor-bolt-shear-check",
      "description": "Calculator unique identifier — must match the endpoint uid."
    },
    "current_unit_system": {
      "type": "string",
      "enum": [
        "metric",
        "imperial",
        ""
      ],
      "default": "metric",
      "description": "Unit system for input values and output display."
    },
    "project_details": {
      "type": "object",
      "description": "Optional project metadata for the PDF report header.",
      "properties": {
        "project_company": {
          "type": "string",
          "default": ""
        },
        "project_name": {
          "type": "string",
          "default": ""
        },
        "project_designer": {
          "type": "string",
          "default": ""
        },
        "project_id": {
          "type": "string",
          "default": ""
        },
        "project_client": {
          "type": "string",
          "default": ""
        },
        "project_notes": {
          "type": "string",
          "default": ""
        }
      }
    }
  }
}