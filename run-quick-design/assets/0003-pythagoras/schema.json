{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Hypotenuse Calculator",
  "description": "Find the hypotenuse of a right angle triangle based on the adjacent and opposite sides.",
  "type": "object",
  "properties": {
    "triangle_image": {
      "type": "string",
      "description": "triangle_image"
    },
    "a": {
      "type": "number",
      "description": "Side A. Units: m",
      "default": 4,
      "minimum": 0,
      "maximum": 1000
    },
    "b": {
      "type": "number",
      "description": "Side B. Units: m",
      "default": 3,
      "minimum": 0,
      "maximum": 1000
    },
    "checkbox_value": {
      "type": "boolean",
      "description": "My Checkbox",
      "default": false
    },
    "uid": {
      "type": "string",
      "const": "0003-pythagoras",
      "description": "Calculator unique identifier — must match the endpoint uid."
    },
    "current_unit_system": {
      "type": "string",
      "enum": [
        "metric",
        "imperial",
        ""
      ],
      "default": "metric",
      "description": "Unit system for input values and output display."
    },
    "project_details": {
      "type": "object",
      "description": "Optional project metadata for the PDF report header.",
      "properties": {
        "project_company": {
          "type": "string",
          "default": ""
        },
        "project_name": {
          "type": "string",
          "default": ""
        },
        "project_designer": {
          "type": "string",
          "default": ""
        },
        "project_id": {
          "type": "string",
          "default": ""
        },
        "project_client": {
          "type": "string",
          "default": ""
        },
        "project_notes": {
          "type": "string",
          "default": ""
        }
      }
    }
  }
}