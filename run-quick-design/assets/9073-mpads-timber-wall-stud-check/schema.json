{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Timber wall stud check for flexure & axial as per NZS 3603",
  "description": "Timber wall stud check for flexure & axial as per NZS 3603",
  "type": "object",
  "properties": {
    "image": {
      "type": "string",
      "description": "image. Diagram of Stud"
    },
    "b": {
      "type": "number",
      "description": "Beam Width (b). Symbol: b. Units: mm",
      "default": 45,
      "minimum": 35,
      "maximum": 400
    },
    "d": {
      "type": "number",
      "description": "Beam Depth (d). Symbol: d. Units: mm",
      "default": 90,
      "minimum": 35,
      "maximum": 1000
    },
    "Lb": {
      "type": "number",
      "description": "Unbraced Length (Lb). Symbol: Lb. Units: mm",
      "default": 1200,
      "minimum": 300,
      "maximum": 10000
    },
    "Lb message": {
      "type": "string",
      "description": "Distance between restraints of portion with compression"
    },
    "fb": {
      "type": "number",
      "description": "Flexure Capacity, fb. Symbol: fb. Units: MPa",
      "default": 14,
      "minimum": 10,
      "maximum": 100
    },
    "fc": {
      "type": "number",
      "description": "Compession Capacity, fc. Symbol: fc. Units: MPa",
      "default": 18,
      "minimum": 10,
      "maximum": 100
    },
    "k4": {
      "type": "number",
      "description": "Parallel factor (k4). Symbol: k4",
      "default": 1,
      "minimum": 1,
      "maximum": 1.33
    },
    "k4 link": {
      "type": "string",
      "description": "See NZS3603.1993 2.9.1 Table 2.7"
    },
    "spa": {
      "type": "number",
      "description": "Joist Spacing (mm). Symbol: spa. Units: mm",
      "default": 400,
      "minimum": 200,
      "maximum": 10000
    },
    "Green": {
      "type": "boolean",
      "description": "Green?",
      "default": false
    },
    "Us_brief": {
      "type": "number",
      "description": "U*_brief (Area load). Symbol: us_b. Units: kPa",
      "default": 1.2,
      "minimum": 0,
      "maximum": 20
    },
    "Ps_brief": {
      "type": "number",
      "description": "P*_brief. Symbol: Ps_b. Units: kN",
      "default": 5,
      "minimum": 0,
      "maximum": 10000
    },
    "E": {
      "type": "number",
      "description": "Mod. of Elasticity. Symbol: E. Units: MPa",
      "default": 9130,
      "minimum": 100,
      "maximum": 20000
    },
    "Span": {
      "type": "number",
      "description": "Span (mm). Symbol: Span. Units: mm",
      "default": 2400,
      "minimum": 100,
      "maximum": 10000
    },
    "DefLimit_Brief": {
      "type": "number",
      "description": "Deflection Limit Denominator (L/XXX) for Brief Loading (See NZS 1170.0 Table C1)",
      "default": 180,
      "minimum": 1,
      "maximum": 1000
    },
    "u_brief": {
      "type": "number",
      "description": "Area load due to Sevice Brief Loads. Symbol: u_b. Units: kPa",
      "default": 0.76,
      "minimum": 0,
      "maximum": 100
    },
    "uid": {
      "type": "string",
      "const": "9073-mpads-timber-wall-stud-check",
      "description": "Calculator unique identifier — must match the endpoint uid."
    },
    "current_unit_system": {
      "type": "string",
      "enum": [
        "metric",
        "imperial",
        ""
      ],
      "default": "metric",
      "description": "Unit system for input values and output display."
    },
    "project_details": {
      "type": "object",
      "description": "Optional project metadata for the PDF report header.",
      "properties": {
        "project_company": {
          "type": "string",
          "default": ""
        },
        "project_name": {
          "type": "string",
          "default": ""
        },
        "project_designer": {
          "type": "string",
          "default": ""
        },
        "project_id": {
          "type": "string",
          "default": ""
        },
        "project_client": {
          "type": "string",
          "default": ""
        },
        "project_notes": {
          "type": "string",
          "default": ""
        }
      }
    }
  }
}