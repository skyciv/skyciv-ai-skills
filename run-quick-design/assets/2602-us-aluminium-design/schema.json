{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ADM 2015 Aluminum Member Design",
  "description": "Design aluminium members in accordance with ADM 2015.",
  "type": "object",
  "properties": {
    "member_label": {
      "type": "string",
      "description": "Member Label. Symbol: Label",
      "default": "Member 1"
    },
    "s3d_section": {
      "type": "string",
      "description": "Section ID. Symbol: Section. Section object imported from S3D model."
    },
    "shape": {
      "type": "string",
      "description": "Shape. Symbol: Shape",
      "enum": [
        "hollow rectangular",
        "hollow circular",
        "i_section",
        "c_section"
      ],
      "x-enumLabels": [
        "Hollow Rectangle",
        "Hollow Circle",
        "I-Section",
        "C-Section"
      ],
      "default": "hollow rectangular"
    },
    "section": {
      "type": "string",
      "description": "Section. Symbol: Section. Select Custom to edit section dimensions.",
      "enum": [
        "custom",
        "RT 1-3/4x1-1/2x1/8"
      ],
      "x-enumLabels": [
        "Custom",
        "RT 1-3/4x1-1/2x1/8"
      ],
      "default": "custom"
    },
    "alloy": {
      "type": "string",
      "description": "Alloy",
      "default": "6005"
    },
    "temper": {
      "type": "string",
      "description": "Temper",
      "default": "T5"
    },
    "welded": {
      "type": "string",
      "description": "Welded. Is the section welded or not.",
      "enum": [
        "No",
        "Yes"
      ],
      "x-enumLabels": [
        "Not Welded",
        "Welded"
      ],
      "default": "Yes"
    },
    "product": {
      "type": "string",
      "description": "Product. ADM specification, product.",
      "enum": [
        "B209, sheet & plate",
        "B210, drawn tube",
        "B221, extrusion",
        "B211, bar, rod, & wire",
        "B247, forging",
        "B928, sheet & plate",
        "B632, tread plate",
        "B241, pipe & tube",
        "B429 pipe & tube",
        "B308, std structural profile"
      ],
      "x-enumLabels": [
        "B209, sheet & plate",
        "B210, drawn tube",
        "B221, extrusion",
        "B211, bar, rod, & wire",
        "B247, forging",
        "B928, sheet & plate",
        "B632, tread plate",
        "B241, pipe & tube",
        "B429 pipe & tube",
        "B308, std structural profile"
      ],
      "default": "B209, sheet & plate"
    },
    "b": {
      "type": "number",
      "description": "Width (b). Units: in. The width of the section.",
      "default": 8,
      "minimum": 0,
      "maximum": 800
    },
    "d": {
      "type": "number",
      "description": "Depth (d). Units: in. The depth of the section. For custom shapes, this is used as an override for the Leg Height.",
      "default": 12,
      "minimum": 0,
      "maximum": 400
    },
    "t1": {
      "type": "number",
      "description": "Thickness (t1). Units: in. Thickness of the web. For custom shapes, this is used as an override for the Leg Thickness.",
      "default": 0.35,
      "minimum": 0,
      "maximum": 20
    },
    "t2": {
      "type": "number",
      "description": "Thickness (t2). Units: in. Thickness of the flange.",
      "default": 0.35,
      "minimum": 0,
      "maximum": 20
    },
    "Ly": {
      "type": "number",
      "description": "Span (Ly). Units: in. The span of the member, as unbraced length in the Y (minor) direction.",
      "default": 48,
      "minimum": 1,
      "maximum": 2000
    },
    "Lz": {
      "type": "number",
      "description": "Span (Lz). Units: in. The span of the member, as unbraced length in the Z (major) direction.",
      "default": 48,
      "minimum": 1,
      "maximum": 2000
    },
    "method": {
      "type": "string",
      "description": "Design Method. Symbol: Method",
      "enum": [
        "ASD",
        "LRFD"
      ],
      "x-enumLabels": [
        "ASD",
        "LRFD"
      ],
      "default": "ASD"
    },
    "Mz": {
      "type": "number",
      "description": "Major Bending (Mz). Units: kip-ft. Moment in major axis (about the Z-axis). ",
      "default": 2.58,
      "minimum": 0,
      "maximum": 500
    },
    "My": {
      "type": "number",
      "description": "Minor Bending (My). Units: kip-ft. Moment in minor axis (about the Y-axis). ",
      "default": 0.5,
      "minimum": 0,
      "maximum": 500
    },
    "Vy": {
      "type": "number",
      "description": "Major Shear (Vy). Units: kip. Shear in minor axis (about the Y-axis). ",
      "default": 5,
      "minimum": 0,
      "maximum": 500000
    },
    "Vz": {
      "type": "number",
      "description": "Minor Shear (Vz). Units: kip. Shear in major axis (about the Z-axis). ",
      "default": 5,
      "minimum": 0,
      "maximum": 500000
    },
    "Nc": {
      "type": "number",
      "description": "Axial Compression (Nc). Units: kip. Axial compression.",
      "default": 1,
      "minimum": 0,
      "maximum": 810
    },
    "Nt": {
      "type": "number",
      "description": "Axial Tension (Nt). Units: kip. Axial tension.",
      "default": 0,
      "minimum": -10000,
      "maximum": 500000
    },
    "uid": {
      "type": "string",
      "const": "2602-us-aluminium-design",
      "description": "Calculator unique identifier — must match the endpoint uid."
    },
    "current_unit_system": {
      "type": "string",
      "enum": [
        "metric",
        "imperial",
        ""
      ],
      "default": "metric",
      "description": "Unit system for input values and output display."
    },
    "project_details": {
      "type": "object",
      "description": "Optional project metadata for the PDF report header.",
      "properties": {
        "project_company": {
          "type": "string",
          "default": ""
        },
        "project_name": {
          "type": "string",
          "default": ""
        },
        "project_designer": {
          "type": "string",
          "default": ""
        },
        "project_id": {
          "type": "string",
          "default": ""
        },
        "project_client": {
          "type": "string",
          "default": ""
        },
        "project_notes": {
          "type": "string",
          "default": ""
        }
      }
    }
  }
}