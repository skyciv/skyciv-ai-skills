{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Solar Sample",
  "description": "Solar Sample for the Structural Design of Roof Photovoltaic Panels",
  "type": "object",
  "properties": {
    "project_name": {
      "type": "string",
      "description": "Project Name",
      "default": "Solar Sample"
    },
    "address": {
      "type": "string",
      "description": "Project Address",
      "default": "New York"
    },
    "roof_number": {
      "type": "string",
      "description": "Roof ID",
      "default": "001"
    },
    "design_code": {
      "type": "string",
      "description": "Design Code",
      "enum": [
        "ibc-2021",
        "irc-2021",
        "irc-2021_ibc-2021"
      ],
      "x-enumLabels": [
        "2021 IBC",
        "2021 IRC",
        "2021 IRC & 2021 IBC"
      ],
      "default": "ibc-2021"
    },
    "number_of_pv_panels": {
      "type": "number",
      "description": "Number of Panels",
      "default": 20
    },
    "area_of_pv_panel": {
      "type": "number",
      "description": "Area of one Panel. Units: sq.ft.",
      "default": 16
    },
    "panels_dead_load": {
      "type": "number",
      "description": "Panels Dead Load. Units: psf",
      "default": 3
    },
    "framing_weight": {
      "type": "number",
      "description": "Framing Weight. Units: psf",
      "default": 0.6
    },
    "misc_weight": {
      "type": "number",
      "description": "Other Weight. Units: psf",
      "default": 1
    },
    "live_load": {
      "type": "number",
      "description": "Live Load. Units: psf",
      "default": 20
    },
    "V": {
      "type": "number",
      "description": "Basic Wind Speed. Units: mi/h",
      "default": 110
    },
    "E": {
      "type": "number",
      "description": "Ground Elevation. Units: ft",
      "default": 0
    },
    "exposure_category": {
      "type": "string",
      "description": "Exposure Category. Based on Section 26.7.3 of ASCE 7-16",
      "enum": [
        "B",
        "C",
        "D"
      ],
      "x-enumLabels": [
        "Exposure B",
        "Exposure C",
        "Exposure D"
      ],
      "default": "B"
    },
    "B": {
      "type": "number",
      "description": "Building Width. Units: ft",
      "default": 30
    },
    "L": {
      "type": "number",
      "description": "Building Length. Units: ft",
      "default": 30
    },
    "pg": {
      "type": "number",
      "description": "Ground Snow Load. Units: psf",
      "default": 28
    },
    "pm": {
      "type": "number",
      "description": "Min. Roof Snow Load. Units: psf",
      "default": 28
    },
    "roof_profile": {
      "type": "string",
      "description": "Roof Profile",
      "enum": [
        "gable",
        "hip",
        "monoslope"
      ],
      "x-enumLabels": [
        "Gable",
        "Hip",
        "Monoslope"
      ],
      "default": "gable"
    },
    "roof_material": {
      "type": "string",
      "description": "Roof Material",
      "enum": [
        "cement-tile",
        "spanish-clay-tile",
        "copper-tin",
        "fiberboard-2inch",
        "corrugated-metal"
      ],
      "x-enumLabels": [
        "Cement Tile",
        "Spanish Clay Tile",
        "Copper or Tin",
        "Fiberboard",
        "Corrugated Metal"
      ],
      "default": "cement-tile"
    },
    "rafter_span": {
      "type": "string",
      "description": "Rafter/Chord Span",
      "enum": [
        "1",
        "2",
        "3"
      ],
      "x-enumLabels": [
        "1 span (simply-supported)",
        "2 spans",
        "3 spans"
      ],
      "default": "3"
    },
    "length_of_rafter_chord": {
      "type": "number",
      "description": "Length of truss chord/rafter. Units: ft",
      "default": 8
    },
    "frame_spacing": {
      "type": "number",
      "description": "Frame Spacing. Units: ft",
      "default": 2
    },
    "roof_angle": {
      "type": "number",
      "description": "Roof Angle/Slope. Units: °",
      "default": 22.6
    },
    "h": {
      "type": "number",
      "description": "Building Height, h. Units: ft",
      "default": 34
    },
    "uid": {
      "type": "string",
      "const": "9000-solar-sample",
      "description": "Calculator unique identifier — must match the endpoint uid."
    },
    "current_unit_system": {
      "type": "string",
      "enum": [
        "metric",
        "imperial",
        ""
      ],
      "default": "metric",
      "description": "Unit system for input values and output display."
    },
    "project_details": {
      "type": "object",
      "description": "Optional project metadata for the PDF report header.",
      "properties": {
        "project_company": {
          "type": "string",
          "default": ""
        },
        "project_name": {
          "type": "string",
          "default": ""
        },
        "project_designer": {
          "type": "string",
          "default": ""
        },
        "project_id": {
          "type": "string",
          "default": ""
        },
        "project_client": {
          "type": "string",
          "default": ""
        },
        "project_notes": {
          "type": "string",
          "default": ""
        }
      }
    }
  }
}