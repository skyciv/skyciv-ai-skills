{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "S3D Concrete Column Design Summary Report",
  "description": "Summary report for concrete column design in S3D.",
  "type": "object",
  "properties": {
    "report_object": {
      "type": "string",
      "description": "report_object"
    },
    "uid": {
      "type": "string",
      "const": "0004-design-concrete-column-s3d-summary-report",
      "description": "Calculator unique identifier — must match the endpoint uid."
    },
    "current_unit_system": {
      "type": "string",
      "enum": [
        "metric",
        "imperial",
        ""
      ],
      "default": "metric",
      "description": "Unit system for input values and output display."
    },
    "project_details": {
      "type": "object",
      "description": "Optional project metadata for the PDF report header.",
      "properties": {
        "project_company": {
          "type": "string",
          "default": ""
        },
        "project_name": {
          "type": "string",
          "default": ""
        },
        "project_designer": {
          "type": "string",
          "default": ""
        },
        "project_id": {
          "type": "string",
          "default": ""
        },
        "project_client": {
          "type": "string",
          "default": ""
        },
        "project_notes": {
          "type": "string",
          "default": ""
        }
      }
    }
  }
}