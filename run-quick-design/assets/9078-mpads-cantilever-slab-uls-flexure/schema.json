{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Basic ULS Flexure Check of Cantilever Slabs as per ACI 318m",
  "description": "Basic ULS Flexure Check of Cantilever Slabs as per ACI 318m",
  "type": "object",
  "properties": {
    "image": {
      "type": "string",
      "description": "image. Diagram of Section"
    },
    "f_c": {
      "type": "number",
      "description": "Concrete Compressive Strength. Symbol: f'_c. Units: MPa",
      "default": 21,
      "minimum": 12.5,
      "maximum": 100
    },
    "f_y": {
      "type": "number",
      "description": "Yield Strength of Reinforcing. Symbol: f_y. Units: MPa",
      "default": 275,
      "minimum": 200,
      "maximum": 1000
    },
    "L": {
      "type": "number",
      "description": "Cantilever Span, L. Symbol: L. Units: mm",
      "default": 1500,
      "minimum": 200,
      "maximum": 10000
    },
    "h": {
      "type": "number",
      "description": "Slab Thickness, h. Symbol: h. Units: mm",
      "default": 100,
      "minimum": 90,
      "maximum": 2000
    },
    "cc": {
      "type": "number",
      "description": "Concrete Cover, cc. Symbol: cc. Units: mm",
      "default": 40,
      "minimum": 20,
      "maximum": 100
    },
    "db_1": {
      "type": "number",
      "description": "Main Reinforcement diameter, db_1. Symbol: db_1. Main Reinforcement diameter, db",
      "enum": [
        6,
        8,
        10,
        12,
        16,
        20
      ],
      "x-enumLabels": [
        "Ø6",
        "Ø8",
        "Ø10",
        "Ø12",
        "Ø16",
        "Ø20"
      ],
      "default": 12
    },
    "db_2": {
      "type": "number",
      "description": "Secondary Reinforcement diameter, db_2. Symbol: db_2. Secondary Reinforcement diameter, db2",
      "enum": [
        6,
        8,
        10,
        12,
        16
      ],
      "x-enumLabels": [
        "Ø6",
        "Ø8",
        "Ø10",
        "Ø12",
        "Ø16"
      ],
      "default": 12
    },
    "spa_inc": {
      "type": "number",
      "description": "Spacing Increment, spa_inc. Symbol: spa_inc. Units: mm",
      "default": 25,
      "minimum": 5,
      "maximum": 100
    },
    "U_D": {
      "type": "number",
      "description": "Area Load - DL, U_D. Symbol: U_D. Units: kPa",
      "default": 0.6,
      "minimum": 0.6,
      "maximum": 50
    },
    "U_L": {
      "type": "number",
      "description": "Area Load - LL, U_L. Symbol: U_L. Units: kPa",
      "default": 1.9,
      "minimum": 0.25,
      "maximum": 50
    },
    "Ø": {
      "type": "number",
      "description": "Reduction Factor, Ø. Symbol: Ø",
      "default": 0.9,
      "minimum": 0.05,
      "maximum": 3
    },
    "uid": {
      "type": "string",
      "const": "9078-mpads-cantilever-slab-uls-flexure",
      "description": "Calculator unique identifier — must match the endpoint uid."
    },
    "current_unit_system": {
      "type": "string",
      "enum": [
        "metric",
        "imperial",
        ""
      ],
      "default": "metric",
      "description": "Unit system for input values and output display."
    },
    "project_details": {
      "type": "object",
      "description": "Optional project metadata for the PDF report header.",
      "properties": {
        "project_company": {
          "type": "string",
          "default": ""
        },
        "project_name": {
          "type": "string",
          "default": ""
        },
        "project_designer": {
          "type": "string",
          "default": ""
        },
        "project_id": {
          "type": "string",
          "default": ""
        },
        "project_client": {
          "type": "string",
          "default": ""
        },
        "project_notes": {
          "type": "string",
          "default": ""
        }
      }
    }
  }
}