{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Sandbox Solar",
  "description": "Structural Design of Roof Photovoltaic Panels as per ASCE 7-16, 2021 IRC, and NDS 2018",
  "type": "object",
  "properties": {
    "project_name": {
      "type": "string",
      "description": "Project Name",
      "default": "Sandbox Solar"
    },
    "address": {
      "type": "string",
      "description": "Address",
      "default": "Colorado"
    },
    "roof_number": {
      "type": "string",
      "description": "Roof Number",
      "default": "001"
    },
    "design_code": {
      "type": "string",
      "description": "Design Code",
      "enum": [
        "irc-2015",
        "irc-2018",
        "ibc-2018",
        "irc-2018_ibc-2018",
        "ibc-2021",
        "irc-2021",
        "irc-2021_ibc-2021",
        "ibc-2024",
        "irc-2024",
        "irc-2024_ibc-2024"
      ],
      "x-enumLabels": [
        "2015 IRC",
        "2018 IRC",
        "2018 IBC",
        "2018 IRC & 2018 IBC",
        "2021 IBC",
        "2021 IRC",
        "2021 IRC & 2021 IBC",
        "2024 IBC",
        "2024 IRC",
        "2024 IRC & 2024 IBC"
      ],
      "default": "ibc-2021"
    },
    "risk_category": {
      "type": "string",
      "description": "Risk Category",
      "enum": [
        "I",
        "II",
        "III",
        "IV"
      ],
      "x-enumLabels": [
        "Risk Category I",
        "Risk Category II",
        "Risk Category III",
        "Risk Category IV"
      ],
      "default": "II"
    },
    "number_of_pv_panels": {
      "type": "number",
      "description": "Number of Panels. Used in calculating the total additional weight due to PV panel installation (for seismic check)",
      "default": 25
    },
    "area_of_pv_panel": {
      "type": "number",
      "description": "Area of one PV Panel. Units: sq.ft.",
      "default": 18
    },
    "panels_dead_load": {
      "type": "number",
      "description": "Panels Dead Load. Units: psf",
      "default": 3
    },
    "decking_weight": {
      "type": "number",
      "description": "Decking Weight. Units: psf",
      "default": 2
    },
    "framing_weight": {
      "type": "number",
      "description": "Framing Weight. Units: psf",
      "default": 0.6
    },
    "misc_weight": {
      "type": "number",
      "description": "Miscellaneous Additional Weight. Units: psf",
      "default": 1
    },
    "live_load": {
      "type": "number",
      "description": "Live Load. Units: psf",
      "default": 20
    },
    "V": {
      "type": "number",
      "description": "Basic Wind Speed. Units: mi/h. See Figures 26.5-1 to 26.5-2 of ASCE 7-16.",
      "default": 110
    },
    "E": {
      "type": "number",
      "description": "Ground Elevation. Units: ft. (Optional) Ground elevation above mean sea level. For calculated Ground Elevation Factor Ke (default value is 1.0)",
      "default": 0
    },
    "exposure_category": {
      "type": "string",
      "description": "Exposure Category. Based on Section 26.7.3 of ASCE 7-16",
      "enum": [
        "B",
        "C",
        "D"
      ],
      "x-enumLabels": [
        "Exposure B",
        "Exposure C",
        "Exposure D"
      ],
      "default": "B"
    },
    "B": {
      "type": "number",
      "description": "Building Width. Units: ft. Used when roof pitch angle is less than 7°, the wind load pressures will be calculated based on Section 29.4.3",
      "default": 30
    },
    "L": {
      "type": "number",
      "description": "Building Length. Units: ft. Used when roof pitch angle is less than 7°, the wind load pressures will be calculated based on Section 29.4.3",
      "default": 30
    },
    "pg": {
      "type": "number",
      "description": "Ground Snow Load. Units: psf",
      "default": 30
    },
    "pm": {
      "type": "number",
      "description": "Min. Roof Snow Load. Units: psf",
      "default": 30
    },
    "surface_roughness": {
      "type": "string",
      "description": "Surface Roughness Category. B. Urban and suburban areas, wooded areas or other terrain with numerous closely spaced obstructions having the size of single-family dwellings or larger. C. Open terrain with scattered obstructions having heights generally less than 30 feet. This category includes flat open country, and grasslands. D. Flat, unobstructed areas and water surfaces. This category includes smooth mud flats, salt flats and unbroken ice.  Above the tree line in windswept mountainous areas In Alaska, in areas where trees do not exist within a 2-mi (3-km) radius of the site.",
      "enum": [
        "B",
        "C",
        "D",
        "above-treeline",
        "alaska-no-trees"
      ],
      "x-enumLabels": [
        "Surface Roughness B",
        "Surface Roughness C",
        "Surface Roughness D",
        "Above the tree line in windswept mountainous areas",
        "In Alaska in areas where trees do not exist..."
      ],
      "default": "B"
    },
    "roof_exposure": {
      "type": "string",
      "description": "Roof Exposure. For determination of Exposure Factor Ce (Table 7.3-1 of ASCE 7-16)",
      "enum": [
        "sheltered",
        "fully-exposed",
        "partially-exposed"
      ],
      "x-enumLabels": [
        "Sheltered",
        "Fully exposed",
        "Partially exposed"
      ],
      "default": "fully-exposed"
    },
    "thermal_condition": {
      "type": "string",
      "description": "Thermal Condition. For determination of Thermal Factor Ct (Table 7.3-2 of ASCE 7-16)",
      "enum": [
        "structure-above-freezing",
        "unheated-open",
        "structure-below-freezing",
        "greenhouse",
        "all-structures"
      ],
      "x-enumLabels": [
        "Structures kept just above freezing and others with cold ventilated roofs...",
        "Unheated and open air structures",
        "Structures intentionally kept below freezing",
        "Continuously heated greenhouses...",
        "All other structures"
      ],
      "default": "structure-above-freezing"
    },
    "SDS": {
      "type": "number",
      "description": "SDS. Short-period Spectral Acceleration from Section 11.4.5 of ASCE 7-16",
      "default": 0.33
    },
    "roof_profile": {
      "type": "string",
      "description": "Roof Profile. Used in calculating design wind pressures and snow load",
      "enum": [
        "gable",
        "hip",
        "monoslope"
      ],
      "x-enumLabels": [
        "Gable",
        "Hip",
        "Monoslope"
      ],
      "default": "gable"
    },
    "roof_material": {
      "type": "string",
      "description": "Roof Material. From Figure R301.4 Dead load of 2015 IRC.",
      "enum": [
        "asbestos-cement-shingles",
        "asphalt-shingles",
        "cement-tile",
        "clay-book-tile-2inch",
        "clay-book-tile-3inch",
        "ludowici-clay-tile",
        "roman-clay-tile",
        "spanish-clay-tile",
        "composition-shingle-3-ply",
        "composition-shingle-4-ply",
        "composition-shingle-5-ply",
        "copper-tin",
        "corrugated-asbestos",
        "metal-deck-20-gage",
        "metal-deck-18-gage",
        "wood-deck-2inch",
        "wood-deck-3inch",
        "fiberboard-2inch",
        "gypsum-sheathing-2inch",
        "standing-seam-metal",
        "trapezoidal-metal",
        "metal-shingles",
        "corrugated-metal"
      ],
      "x-enumLabels": [
        "Asbestos-cement shingles (4 psf)",
        "Asphalt shingles (2 psf)",
        "Cement tile (16 psf)",
        "Clay - Book tile 2-inch (with mortar) (22 psf)",
        "Clay - Book tile 3-inch (with mortar) (30 psf)",
        "Ludowici Clay tile (with mortar) (20 psf)",
        "Roman Clay tile (with mortar) (22 psf)",
        "Spanish Clay tile (with mortar) (29 psf)",
        "Composition Shingle - Three-ply ready roofing (1 psf)",
        "Composition Shingle - Four-ply felt and gravel (5.5 psf)",
        "Composition Shingle - Five-ply felt and gravel (6 psf)",
        "Copper or tin (1 psf)",
        "Corrugated asbestos-cement roofing (4 psf)",
        "Deck metal 20 gage (2.5 psf)",
        "Deck metal 18 gage (3 psf)",
        "Decking 2-inch wood (Douglas fir) (5 psf)",
        "Decking 3-inch wood (Douglas fir) (8 psf)",
        "Fiberboard 2-inch (0.75 psf)",
        "Gypsum sheathing 2-inch (2 psf)",
        "Standing Seam Metal (3 psf)",
        "Trapezoidal Metal (3 psf)",
        "Metal Shingles (3 psf)",
        "Corrugated Metal (3 psf)"
      ],
      "default": "asphalt-shingles"
    },
    "rafter_span": {
      "type": "string",
      "description": "Rafter/Chord Span. Used in calculating applied shear and moment forces, and deflections (based on Table 3-22c of AISC-15)",
      "enum": [
        "1",
        "2",
        "3"
      ],
      "x-enumLabels": [
        "1 span (simply-supported)",
        "2 spans",
        "3 spans"
      ],
      "default": "3"
    },
    "image_1span": {
      "type": "string",
      "description": "image_1span. 1 span"
    },
    "image_2span": {
      "type": "string",
      "description": "image_2span. 2 span"
    },
    "image_3span": {
      "type": "string",
      "description": "image_3span. 3 span"
    },
    "length_of_rafter_chord": {
      "type": "number",
      "description": "Length of truss chord/rafter. Units: ft",
      "default": 8
    },
    "frame_spacing": {
      "type": "number",
      "description": "Frame Spacing. Units: ft",
      "default": 2
    },
    "roof_angle": {
      "type": "number",
      "description": "Roof Angle/Slope. Units: °. used in calculating wind and snow load",
      "default": 22.6
    },
    "h": {
      "type": "number",
      "description": "Mean roof height of the building, h. Units: ft. Mean roof height of the building",
      "default": 30
    },
    "construction_type": {
      "type": "string",
      "description": "Construction Type",
      "enum": [
        "manufactured-truss",
        "rafter"
      ],
      "x-enumLabels": [
        "Manufactured Truss",
        "Rafter"
      ],
      "default": "manufactured-truss"
    },
    "section_size": {
      "type": "string",
      "description": "Section Size",
      "enum": [
        "2 x 4",
        "2 x 6",
        "2 x 8",
        "2 x 10",
        "2 x 12",
        "4 x 6",
        "4 x 8",
        "4 x 10",
        "4 x 12"
      ],
      "x-enumLabels": [
        "2 x 4",
        "2 x 6",
        "2 x 8",
        "2 x 10",
        "2 x 12",
        "4 x 6",
        "4 x 8",
        "4 x 10",
        "4 x 12"
      ],
      "default": "2 x 4"
    },
    "wood_specie": {
      "type": "string",
      "description": "Wood Specie",
      "enum": [
        "DOUGLAS FIR-LARCH_No.2"
      ],
      "x-enumLabels": [
        "DOUGLAS FIR-LARCH (No.2)"
      ],
      "default": "DOUGLAS FIR-LARCH_No.2"
    },
    "attachment_tributary_width": {
      "type": "number",
      "description": "Attachment Tributary Width. Units: ft. Spacing of attachment along the rails",
      "default": 2.75
    },
    "attachment_spacing": {
      "type": "number",
      "description": "Attachment Spacing. Units: ft. Spacing of attachment between rails",
      "default": 4
    },
    "fastener_method": {
      "type": "string",
      "description": "Fastener method",
      "enum": [
        "lag-screw",
        "direct-to-decking",
        "direct-to-metal-standing-seam",
        "direct-to-metal-trapezoidal",
        "direct-to-metal-corrugated-metal",
        "direct-to-metal-tile",
        "clamps"
      ],
      "x-enumLabels": [
        "5/16 in. Lag Screw",
        "Direct to Decking",
        "Direct to Metal Roof - Standing Seam",
        "Direct to Metal Roof - Trapezoidal",
        "Direct to Metal Roof - Corrugated Metal",
        "Direct to Metal Roof - Tile",
        "Clamps"
      ],
      "default": "lag-screw"
    },
    "lag_penetration": {
      "type": "number",
      "description": "Lag Penetration. Units: in",
      "default": 3.67
    },
    "W_lag_screw": {
      "type": "number",
      "description": "Ref. Withdrawal Value W. Units: lb/in",
      "default": 266
    },
    "Z_lag_screw": {
      "type": "number",
      "description": "Ref. Lateral Value, Z. Units: lb",
      "default": 270
    },
    "reporting": {
      "type": "string",
      "description": "Show Calculation",
      "enum": [
        "yes",
        "no"
      ],
      "x-enumLabels": [
        "Yes",
        "No"
      ],
      "default": "yes"
    },
    "uid": {
      "type": "string",
      "const": "9002-sandbox-solar",
      "description": "Calculator unique identifier — must match the endpoint uid."
    },
    "current_unit_system": {
      "type": "string",
      "enum": [
        "metric",
        "imperial",
        ""
      ],
      "default": "metric",
      "description": "Unit system for input values and output display."
    },
    "project_details": {
      "type": "object",
      "description": "Optional project metadata for the PDF report header.",
      "properties": {
        "project_company": {
          "type": "string",
          "default": ""
        },
        "project_name": {
          "type": "string",
          "default": ""
        },
        "project_designer": {
          "type": "string",
          "default": ""
        },
        "project_id": {
          "type": "string",
          "default": ""
        },
        "project_client": {
          "type": "string",
          "default": ""
        },
        "project_notes": {
          "type": "string",
          "default": ""
        }
      }
    }
  }
}