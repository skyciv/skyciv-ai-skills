{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CSA O86-14 Timber Member Design",
  "description": "Design structural timber members in accordance with CSA O86-14.",
  "type": "object",
  "properties": {
    "standard": {
      "type": "string",
      "description": "Standard. Symbol: Standard. Standard used for calculations.",
      "enum": [
        "CSA O86-14"
      ],
      "x-enumLabels": [
        "CSA O86-14"
      ],
      "default": "CSA O86-14"
    },
    "selection": {
      "type": "string",
      "description": "Selection. Symbol: Selections. Method of selection used",
      "enum": [
        "Lookup",
        "Custom"
      ],
      "x-enumLabels": [
        "Lookup",
        "Custom"
      ],
      "default": "Lookup"
    },
    "cat_input": {
      "type": "string",
      "description": "Category. Symbol: Category. Category of the timber section.",
      "enum": [
        "Sawn",
        "Light",
        "MSR",
        "MEL"
      ],
      "x-enumLabels": [
        "Sawn Framing",
        "Light Framing",
        "Machine stress rated (MSR)",
        "Machine evaluated lumber (MEL)"
      ],
      "default": "Sawn"
    },
    "cat_sawn": {
      "type": "string",
      "description": "Sawn subcategory. Symbol: Cat_{Sawn}. Subcategory of sawn timber.",
      "enum": [
        "A",
        "C",
        "D"
      ],
      "x-enumLabels": [
        "Structural framing",
        "Beam and stringer",
        "Post and timber"
      ],
      "default": "A"
    },
    "species": {
      "type": "string",
      "description": "Species. Symbol: Species. Species of timber.",
      "enum": [
        "SPF",
        "North",
        "HFir",
        "DFir"
