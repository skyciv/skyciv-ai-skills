      "x-enumLabels": [
        "Surfaced",
        "Rough"
      ],
      "default": "Surfaced"
    },
    "n_ply": {
      "type": "number",
      "description": "Number of plies. Symbol: n_{ply}. Number of plies for built-up members.",
      "default": 1,
      "minimum": 1,
      "maximum": 5
    },
    "L_z": {
      "type": "number",
      "description": "Lz. Symbol: L_{z}. Units: mm. Unbraced length about the Z Axis.",
      "default": 1800,
      "minimum": 1,
      "maximum": 1000000
    },
    "L_y": {
      "type": "number",
      "description": "Ly. Symbol: L_{y}. Units: mm. Unbraced length about the Y Axis.",
      "default": 1800,
      "minimum": 1,
      "maximum": 1000000
    },
    "duration_factor": {
      "type": "string",
      "description": "Load duration factor. Symbol: K_{D}. Considers the duration of the load.",
      "enum": [
        "Short",
        "Normal",
        "Long",
        "Custom"
      ],
      "x-enumLabels": [
        "Short",
        "Normal",
        "Long",
        "Custom"
      ],
      "default": "Normal"
    },
    "duration_custom": {
      "type": "number",
      "description": "KD-Custom. Symbol: K_{D-Custom}. Custom Load duration factor.",
      "default": 1,
      "minimum": 0.65,
      "maximum": 1.15
    },
    "system_factor": {
      "type": "string",
      "description": "System factor. Symbol: K_{H}. Considers load sharing between repetitive members.",
      "enum": [
        "NoShare",
        "Case 1",
        "Case 2"
      ],
      "x-enumLabels": [
        "None",
        "Case 1",
        "Case 2"
      ],
      "default": "NoShare"
    },
    "condition_factor": {
      "type": "string",
      "description": "Service condition factor. Symbol: K_{S}. Considers the member conditions (dry or wet).",
      "enum": [
        "Dry"
      ],
      "x-enumLabels": [
        "Dry"
      ],
      "default": "Dry"
    },
    "treatment_factor": {
      "type": "string",
      "description": "Treatment factor. Symbol: K_{T}. Considers the member treatment.",
      "enum": [
        "NoTreat"
      ],
      "x-enumLabels": [
        "None"
      ],
      "default": "NoTreat"
    },
    "M_fz": {
      "type": "number",
      "description": "Mfz. Symbol: M_{fz}. Units: kN*m. Major Axis Factored moment (About the Z-Axis).",
      "default": 0.5,
      "minimum": 0,
      "maximum": 5000000
    },
    "M_fy": {
      "type": "number",
      "description": "Mfy. Symbol: M_{fy}. Units: kN*m. Minor Axis Factored Moment (About the Y-Axis).",
      "default": 0.1,
      "minimum": 0,
      "maximum": 5000000
    },
    "V_fy": {
      "type": "number",
      "description": "Vfy. Symbol: V_{fy}. Units: kN. Major Axis Factored Shear (Y direction).",
      "default": 2,
      "minimum": 0,
      "maximum": 500000
    },
    "V_fz": {
      "type": "number",
      "description": "Vfz. Symbol: V_{fz}. Units: kN. Minor Axis Factored Shear (Z direction).",
      "default": 1,
      "minimum": 0,
      "maximum": 500000
    },
    "C_f": {
      "type": "number",
      "description": "Cfx. Symbol: C_{f}. Units: kN. Factored Axial Load (X direction, Tension negative).",
      "default": 2,
      "minimum": 0,
      "maximum": 500000
    },
    "analysis_results": {
      "type": "string",
      "description": "analysis_results"
    },
    "comb_Kd": {
      "type": "string",
      "description": "comb_Kd"
    },
    "uid": {
      "type": "string",
      "const": "4001-wood-beam-calculator",
      "description": "Calculator unique identifier — must match the endpoint uid."
    },
    "current_unit_system": {
      "type": "string",
      "enum": [
        "metric",
        "imperial",
        ""
      ],
      "default": "metric",
      "description": "Unit system for input values and output display."
    },
    "project_details": {
      "type": "object",
      "description": "Optional project metadata for the PDF report header.",
      "properties": {
        "project_company": {
          "type": "string",
          "default": ""
        },
        "project_name": {
          "type": "string",
          "default": ""
        },
        "project_designer": {
          "type": "string",
          "default": ""
        },
        "project_id": {
          "type": "string",
          "default": ""
        },
        "project_client": {
          "type": "string",
          "default": ""
        },
        "project_notes": {
          "type": "string",
          "default": ""
        }
      }
