    "b": {
      "type": "number",
      "description": "Nominal Width (b). Units: in",
      "default": 4,
      "minimum": 1,
      "maximum": 24
    },
    "d": {
      "type": "number",
      "description": "Nominal Depth (d). Units: in",
      "default": 10,
      "minimum": 3,
      "maximum": 24
    },
    "L": {
      "type": "number",
      "description": "Un-supported Length of Beam (L). Units: ft",
      "default": 15,
      "minimum": 1,
      "maximum": 200
    },
    "Le": {
      "type": "number",
      "description": "Effective Length for Bending. Units: ft. Default value is 2.06 * L as this is the most conservative value.",
      "default": 30.9,
      "minimum": 1,
      "maximum": 412
    },
    "kz": {
      "type": "number",
      "description": "Effective Length Factor- Major (kz). Symbol: k_z",
      "default": 1,
      "minimum": 0.1,
      "maximum": 5000
    },
    "ky": {
      "type": "number",
      "description": "Effective Length Factor- Minor (ky). Symbol: k_y",
      "default": 0.5,
      "minimum": 0.1,
      "maximum": 5000
    },
    "mc": {
      "type": "number",
      "description": "Moisture Content (%). Symbol: m_{c}. Percentage of Moisture Content.",
      "default": 18,
      "minimum": 0,
      "maximum": 100
    },
    "temp": {
      "type": "number",
      "description": "Temperature (°F). Units: F",
      "default": 50,
      "minimum": 0,
      "maximum": 200
    },
    "msc": {
      "type": "string",
      "description": "Moisture Service Condition. Symbol: m_{sc}",
      "enum": [
        "Dry",
        "Wet"
      ],
      "x-enumLabels": [
        "Dry",
        "Wet"
      ],
      "default": "Dry"
    },
    "df_LL": {
      "type": "number",
      "description": "dfLL. Symbol: df_{LL}. Deflection Limit- Live Load.",
      "default": 360,
      "minimum": 100,
      "maximum": 360
    },
    "df_LT": {
      "type": "number",
      "description": "dfLT. Symbol: df_{LT}. Deflection Limit- Long Term Load.",
      "default": 180,
      "minimum": 100,
      "maximum": 360
    },
    "ad_LL": {
      "type": "number",
      "description": "adLL. Symbol: ad_{LL}. Units: in. Actual Deflection- Live Load.",
      "default": 0.1,
      "minimum": 0.01,
      "maximum": 100
    },
    "ad_LT": {
      "type": "number",
      "description": "adLT. Symbol: ad_{LT}. Units: in. Actual Deflection- Long Term Load.",
      "default": 0.12,
      "minimum": 0.01,
      "maximum": 100
    },
    "lambda_c": {
      "type": "number",
      "description": "λperm_c. Symbol: λ_{perm,c}. Allowable Slenderness Ratio- Compression.",
      "default": 50,
      "minimum": 50,
      "maximum": 200
    },
    "lambda_b": {
      "type": "number",
      "description": "λperm_b. Symbol: λ_{perm,b}. Allowable Slenderness Ratio- Bending.",
      "default": 50,
      "minimum": 50,
      "maximum": 200
    },
    "bp": {
      "type": "string",
      "description": "Bending Pattern. Symbol: b_{p}",
      "enum": [
        "Sagging",
        "Hogging"
      ],
      "x-enumLabels": [
        "Sagging",
        "Hogging"
      ],
      "default": "Sagging"
    },
    "Mz": {
      "type": "number",
      "description": "Major Bending (Mz). Symbol: M_z. Units: kip-ft. ",
      "default": 0.4,
      "minimum": 0,
      "maximum": 500
    },
    "My": {
      "type": "number",
      "description": "Minor Bending (My). Symbol: M_y. Units: kip-ft. ",
      "default": 0.1,
      "minimum": 0,
      "maximum": 500
    },
    "Vz": {
      "type": "number",
      "description": "Minor Shear (Vz). Symbol: V_z. Units: kip. ",
      "default": 2.5,
      "minimum": 0,
      "maximum": 100
    },
    "Vy": {
      "type": "number",
      "description": "Major Shear (Vy). Symbol: V_y. Units: kip. ",
      "default": 2.5,
      "minimum": 0,
      "maximum": 100
    },
    "Nc": {
      "type": "number",
      "description": "Axial Compression (Nc). Symbol: N_c. Units: kip. ",
      "default": 10,
      "minimum": 0,
      "maximum": 100
    },
    "Nt": {
      "type": "number",
      "description": "Axial Tension (Nt). Symbol: N_t. Units: kip. ",
      "default": 1,
      "minimum": 0,
      "maximum": 100
    },
    "uid": {
      "type": "string",
      "const": "4003-nds-wood-beam-calculator",
      "description": "Calculator unique identifier — must match the endpoint uid."
    },
    "current_unit_system": {
      "type": "string",
      "enum": [
        "metric",
        "imperial",
        ""
      ],
      "default": "metric",
      "description": "Unit system for input values and output display."
    },
    "project_details": {
      "type": "object",
      "description": "Optional project metadata for the PDF report header.",
      "properties": {
        "project_company": {
