        "DOUGLAS FIR-SOUTH",
        "EASTERN HEMLOCK-BALSAM FIR",
        "EASTERN HEMLOCK-TAMARACK",
        "EASTERN SOFTWOODS",
        "EASTERN WHITE PINE",
        "HEM-FIR",
        "HEM-FIR (NORTH)",
        "MIXED MAPLE",
        "MIXED OAK",
        "NORTHERN RED OAK",
        "NORTHERN SPECIES",
        "NORTHERN WHITE CEDAR",
        "RED MAPLE",
        "RED OAK",
        "REDWOOD",
        "SPRUCE-PINE-FIR",
        "SPRUCE-PINE-FIR (SOUTH)",
        "WESTERN CEDARS",
        "WESTERN WOODS",
        "WHITE OAK",
        "YELLOW CEDAR",
        "YELLOW POPLAR"
      ],
      "default": "DOUGLAS FIR-LARCH"
    },
    "grade": {
      "type": "string",
      "description": "Commercial Grade. Symbol: c_g",
      "enum": [
        "-",
        "Select Structural",
        "No.1 & Btr",
        "No.1",
        "No.2",
        "No.3",
        "Stud",
        "Construction",
        "Standard",
        "Utility"
      ],
      "x-enumLabels": [
        "Please Select",
        "Select Structural",
        "No.1 & Btr",
        "No.1",
        "No.2",
        "No.3",
        "Stud",
        "Construction",
        "Standard",
        "Utility"
      ],
      "default": "No.1"
    },
    "size": {
      "type": "string",
      "description": "Size Classification. Symbol: s_c",
      "enum": [
        "-",
        "2in & wider"
      ],
      "x-enumLabels": [
        "Please Select",
        "2in & wider"
      ],
      "default": "2in & wider"
    },
    "laminations": {
      "type": "number",
      "description": "Number of Laminations. Symbol: n_{lam}",
      "default": 2,
      "minimum": 1,
      "maximum": 10
    },
    "Cr_app": {
      "type": "boolean",
      "description": "Repetitive Factor Applicable?. Symbol: -. Is the member meeting criteria specified in Cl. 4.3.9 for repetitive factor ( Cr ). If yes, then Cr = 1.15, else Cr = 1.0.",
      "default": false
    },
    "Ci_app": {
      "type": "boolean",
      "description": "Incision Factor Applicable?. Symbol: -. Is the dimension lumber considered as incised lumber as per Cl. 4.3.8 ? If yes, then incision factor Ci is as per table 4.3.8, else Ci = 1.0.",
      "default": false
    },
    "auto_adjust": {
      "type": "boolean",
      "description": "Automatically Update Adjustment Factors?. Symbol: -. If checked the calculator will automatically adjust input factors as your input is changed. If unchecked you will need to manually update the adjustment factors.",
      "default": true
    },
    "adjust_factor_asd": {
      "type": "array",
      "description": "Adjustment Factors",
      "items": {
        "type": "object",
        "properties": {
          "item_name": {
            "type": "string",
            "description": "Item",
            "default": "E",
