{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NDS<sup>®</sup> 2018 Wood Member Design",
  "description": "Design structural wood members in accordance with NDS® 2018.",
  "type": "object",
  "properties": {
    "s3d_section": {
      "type": "string",
      "description": "Section ID. Symbol: Section. Section object imported from S3D model."
    },
    "method": {
      "type": "string",
      "description": "Design Method. Symbol: Method",
      "enum": [
        "ASD",
        "LRFD"
      ],
      "x-enumLabels": [
        "ASD",
        "LRFD"
      ],
      "default": "ASD"
    },
    "adjust_factor_only": {
      "type": "boolean",
      "description": "Adjustment Factory Flag",
      "default": false
    },
    "table_no": {
      "type": "string",
      "description": "NDS® Table. Symbol: Table",
      "enum": [
        "Table 4A",
        "Table 4B",
        "Table 4C",
        "Table 4D",
        "Table 4F",
        "Table 5A",
        "Table 5B",
        "Table 5C",
        "Table 5D"
      ],
      "x-enumLabels": [
        "Table 4A",
        "Table 4B",
        "Table 4C",
        "Table 4D",
        "Table 4F",
        "Table 5A",
        "Table 5B",
        "Table 5C",
        "Table 5D"
      ],
      "default": "Table 4A"
    },
    "species": {
      "type": "string",
      "description": "Species. Symbol: S_p",
      "enum": [
        "-",
        "ALASKA CEDAR",
        "ALASKA HEMLOCK",
        "ALASKA SPRUCE",
        "ALASKA YELLOW CEDAR",
        "ASPEN",
        "BALDCYPRESS",
        "BEECH-BIRCH-HICKORY",
        "COAST SITKA SPRUCE",
        "COTTONWOOD",
        "DOUGLAS FIR-LARCH",
        "DOUGLAS FIR-LARCH (NORTH)",
        "DOUGLAS FIR-SOUTH",
        "EASTERN HEMLOCK-BALSAM FIR",
        "EASTERN HEMLOCK-TAMARACK",
        "EASTERN SOFTWOODS",
        "EASTERN WHITE PINE",
        "HEM-FIR",
        "HEM-FIR (NORTH)",
        "MIXED MAPLE",
        "MIXED OAK",
        "NORTHERN RED OAK",
        "NORTHERN SPECIES",
        "NORTHERN WHITE CEDAR",
        "RED MAPLE",
        "RED OAK",
        "REDWOOD",
        "SPRUCE-PINE-FIR",
        "SPRUCE-PINE-FIR (SOUTH)",
        "WESTERN CEDARS",
        "WESTERN WOODS",
        "WHITE OAK",
        "YELLOW CEDAR",
        "YELLOW POPLAR"
      ],
      "x-enumLabels": [
        "Please Select",
        "ALASKA CEDAR",
        "ALASKA HEMLOCK",
        "ALASKA SPRUCE",
        "ALASKA YELLOW CEDAR",
        "ASPEN",
        "BALDCYPRESS",
