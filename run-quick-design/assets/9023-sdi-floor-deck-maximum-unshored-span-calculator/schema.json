{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SDI Roof Deck Load Table Calculator",
  "description": "Calculator for load capacity of SDI roof deck.",
  "type": "object",
  "properties": {
    "rect_image": {
      "type": "string",
      "description": "rect_image. Image showing the height and width of a rectangle"
    },
    "decking_profile": {
      "type": "string",
      "description": "Decking Profile. Symbol: Profile. Select the profile (shape) of SDI roof deck sheet.",
      "enum": [
        "NR",
        "IR",
        "WR",
        "DR",
        "BA",
        "NA",
        "2x12",
        "3x12",
        "9/16",
        "Custom"
      ],
      "x-enumLabels": [
        "NR (A)",
        "IR (F)",
        "WR (B)",
        "DR (N)",
        "BA",
        "NA",
        "2 x 12",
        "3 x 12",
        "9/16 Form Deck",
        "Custom"
      ],
      "default": "WR"
    },
    "decking_gage_standard": {
      "type": "number",
      "description": "Decking Gage. Symbol: Gage. Select the gage (thickness) of SDI decking sheet. Note, only 9/16 profile supports 24 and 26 gage and does not support 16 and 18 gage.",
      "enum": [
        22,
        20,
        18,
        16
      ],
      "x-enumLabels": [
        "22",
        "20",
        "18",
        "16"
      ],
      "default": 22
    },
    "decking_gage_alt": {
      "type": "number",
      "description": "Decking Gage. Symbol: Gage. Select the gage (thickness) of SDI decking sheet. Note, only 9/16 profile supports 24 and 26 gage and does not support 16 and 18 gage.",
      "enum": [
        26,
        24,
        22,
        20
      ],
      "x-enumLabels": [
        "26",
        "24",
        "22",
        "20"
      ],
      "default": 22
    },
    "decking_profile_custom": {
      "type": "string",
      "description": "Profile Name. Symbol: Custom \\; Profile. Please enter the name of the custom decking profile.",
      "default": "[Input Name]"
    },
    "custom_profile_table": {
      "type": "array",
      "description": "Section Properties",
      "items": {
        "type": "object",
        "properties": {
          "deck_height_custom": {
            "type": "number",
            "description": "Deck Height (in)",
            "default": 3,
            "minimum": 0,
            "maximum": 10000
          },
          "deck_spacing_custom": {
            "type": "number",
            "description": "Deck Spacing (in)",
            "default": 12,
            "minimum": 0,
            "maximum": 10000
          },
          "deck_gage_custom": {
            "type": "number",
            "description": "Decking Gage",
            "default": 18,
            "minimum": 0,
            "maximum": 10000
          },
          "yield_strength_custom": {
            "type": "number",
            "description": "Yield Strength (ksi)",
            "default": 40,
            "minimum": 0,
            "maximum": 10000
          },
          "I_pos_custom": {
            "type": "number",
            "description": "Positive Moment of Inertia (in4)",
            "default": 40,
            "minimum": 0,
            "maximum": 100000
          },
          "I_neg_custom": {
            "type": "number",
            "description": "Negative Moment of Inertia (in4)",
            "default": 40,
            "minimum": 0,
            "maximum": 100000
          },
          "section_modulus_pos_custom": {
            "type": "number",
            "description": "Positive Section Modulus (in3)",
            "default": 0.75,
            "minimum": 0,
            "maximum": 100000
          },
          "section_modulus_neg_custom": {
            "type": "number",
            "description": "Negative Section Modulus (in3)",
            "default": 0.75,
            "minimum": 0,
            "maximum": 100000
          },
          "shear_capacity_custom": {
            "type": "number",
            "description": "Shear Capacity (lbs)",
            "default": 6000,
            "minimum": 0,
            "maximum": 100000
          },
          "ext_crippling_A_custom": {
            "type": "number",
            "description": "Exterior Crippling Factor A",
            "default": 300,
            "minimum": 0,
            "maximum": 100000
          },
          "ext_crippling_B_custom": {
            "type": "number",
            "description": "Exterior Crippling Factor B",
            "default": 1.5,
            "minimum": 0,
            "maximum": 100000
          },
          "int_crippling_A_custom": {
            "type": "number",
            "description": "Interior Crippling Factor A",
            "default": 500,
            "minimum": 0,
            "maximum": 100000
          },
          "int_crippling_B_custom": {
            "type": "number",
            "description": "Interior Crippling Factor B",
            "default": 1,
            "minimum": 0,
            "maximum": 100000
          },
          "deck_weight_custom": {
            "type": "number",
            "description": "Decking Weight (psf)",
            "default": 2.5,
            "minimum": 0,
            "maximum": 100000
          }
        }
      }
    },
    "yield_strength": {
      "type": "number",
      "description": "Yield Strength. Symbol: f_y. Units: ksi. Select the yield strength (in ksi) of the SDI decking sheet.",
      "enum": [
        33,
        40,
        50,
        80
      ],
      "x-enumLabels": [
        "33",
        "40",
        "50",
        "80"
      ],
      "default": 40
    },
    "end_bearing": {
      "type": "number",
      "description": "End Bearing Width. Symbol: End\\; Bearing. Units: in. The bearing support width for decking sheets at the ends of the continuous spans.",
      "default": 12,
      "minimum": 0,
      "maximum": 10000
    },
    "int_bearing": {
      "type": "number",
      "description": "Interior Bearing Width. Symbol: Interior\\; Bearing. Units: in. The bearing support width for decking sheets at internal supports.",
      "default": 12,
      "minimum": 0,
      "maximum": 10000
    },
    "design_methodology": {
      "type": "string",
      "description": "Design Methodology. Symbol: Methodology. Select from ASD or LFRD design methodology.",
      "enum": [
        "LRFD",
        "ASD"
      ],
      "x-enumLabels": [
        "LRFD",
        "ASD"
      ],
      "default": "LRFD"
    },
    "load_orientation": {
      "type": "string",
      "description": "Load Orientation. Symbol: Orientation. Orientation of loading applied across all spans",
      "enum": [
        "Gravity",
        "Uplift"
      ],
      "x-enumLabels": [
        "Gravity",
        "Uplift"
      ],
      "default": "Gravity"
    },
    "deflection_criteria": {
      "type": "number",
      "description": "Deflection Criteria. Symbol: Deflection. Select the deflection limits that should be checked.",
      "enum": [
        120,
        180,
        240
      ],
      "x-enumLabels": [
        "L/120",
        "L/180",
        "L/240"
      ],
      "default": 120
    },
    "span_range_min": {
      "type": "number",
      "description": "Table Span Minimum Value. Symbol: Span\\; Min. Units: ft. Minimum value for span ranges provided in table",
      "default": "6",
      "minimum": 1,
      "maximum": 1000
    },
    "span_increment": {
      "type": "number",
      "description": "Table span increments. Symbol: Span\\; Increment. Units: ft. Increments of spans lengths to be presented in the table, starting from minimum  ",
      "enum": [
        0.25,
        0.33,
        0.5,
        1,
        2
      ],
      "x-enumLabels": [
        0.25,
        0.33,
        0.5,
        1,
        2
      ],
      "default": 0.5
    },
    "report_span": {
      "type": "number",
      "description": "Span for Calculation Report. Units: ft. Input span to be used in the calculation report",
      "default": "10",
      "minimum": 1,
      "maximum": 1000
    },
    "design_pressure": {
      "type": "number",
      "description": "Design Pressure (Optional). Symbol: Design\\; Pressure. Units: psf. Optional input for design pressure to compare against maximum loads",
      "default": 0,
      "minimum": 0,
      "maximum": 1000
    },
    "uid": {
      "type": "string",
      "const": "9023-sdi-floor-deck-maximum-unshored-span-calculator",
      "description": "Calculator unique identifier — must match the endpoint uid."
    },
    "current_unit_system": {
      "type": "string",
      "enum": [
        "metric",
        "imperial",
        ""
      ],
      "default": "metric",
      "description": "Unit system for input values and output display."
    },
    "project_details": {
      "type": "object",
      "description": "Optional project metadata for the PDF report header.",
      "properties": {
        "project_company": {
          "type": "string",
          "default": ""
        },
        "project_name": {
          "type": "string",
          "default": ""
        },
        "project_designer": {
          "type": "string",
          "default": ""
        },
        "project_id": {
          "type": "string",
          "default": ""
        },
        "project_client": {
          "type": "string",
          "default": ""
        },
        "project_notes": {
          "type": "string",
          "default": ""
        }
      }
    }
  }
}